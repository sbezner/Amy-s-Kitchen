# Firebase web config — copy this file to `.env.local` and fill in the values
# from the Firebase console (Project settings → General → Your apps → Web app).
# These keys are safe to ship in the client bundle; security is enforced by
# Firestore rules.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
