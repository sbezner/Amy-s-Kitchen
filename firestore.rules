rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function userExists() { return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function isApproved() { return userExists() && userDoc().status == 'approved'; }
    function isAmy() { return userExists() && userDoc().role == 'amy' && userDoc().status == 'approved'; }
    function isSelf(uid) { return isSignedIn() && request.auth.uid == uid; }

    match /users/{uid} {
      // Self can read own doc; any approved user can read other users
      // (needed for reports/threshold calculations and to show display
      // names alongside ratings); Amy can also read pending sign-ups.
      allow read: if isSelf(uid) || isApproved();

      // First-time create must be self, employee, pending (no privilege
      // escalation). Exception: a hardcoded admin email may create its
      // own doc as approved admin — this is the defensive bootstrap
      // for when Firebase account-linking misses (e.g. an admin's
      // Google sign-in gets a fresh UID instead of linking to their
      // existing email-link account). Keep this list in sync with
      // ADMIN_EMAILS in src/lib/allowedDomains.ts.
      allow create: if isSelf(uid)
        && (
          (request.resource.data.role == 'employee'
            && request.resource.data.status == 'pending')
          ||
          (request.auth.token.email in ['sbezner@gmail.com', 'abezner@gmail.com']
            && request.resource.data.role == 'amy'
            && request.resource.data.status == 'approved')
        );

      // Self can only update displayName (role + status are immutable from client).
      allow update: if isAmy()
        || (isSelf(uid)
            && request.resource.data.role == resource.data.role
            && request.resource.data.status == resource.data.status
            && request.resource.data.email == resource.data.email);

      allow delete: if false;
    }

    match /mealLibrary/{libId} {
      allow read: if isApproved();
      // Any approved user can add or edit meals; only Amy can delete.
      allow create, update: if isApproved();
      allow delete: if isAmy();
    }

    match /servings/{servingId} {
      allow read: if isApproved();
      // Any approved user can schedule or edit a serving; only Amy can delete.
      allow create, update: if isApproved();
      allow delete: if isAmy();

      match /ratings/{uid} {
        allow read: if isApproved();
        // Employee writes their own rating; Amy can hide/unhide and delete.
        allow create: if (isSelf(uid) && isApproved()
                          && request.resource.data.stars is int
                          && request.resource.data.stars >= 1
                          && request.resource.data.stars <= 5
                          && request.resource.data.get('hiddenByAmy', false) == false)
                         || isAmy();
        allow update: if (isSelf(uid) && isApproved()
                          && request.resource.data.stars is int
                          && request.resource.data.stars >= 1
                          && request.resource.data.stars <= 5
                          && request.resource.data.get('hiddenByAmy', false) == resource.data.get('hiddenByAmy', false))
                         || isAmy();
        allow delete: if isSelf(uid) || isAmy();
      }

      match /lookingForward/{uid} {
        allow read: if isApproved();
        allow write: if isSelf(uid) && isApproved();
      }
    }

    match /requests/{reqId} {
      allow read: if isApproved();
      allow create: if isApproved() && request.resource.data.requestedBy == request.auth.uid;
      allow update: if isAmy()
        || (isApproved()
            && resource.data.requestedBy == request.auth.uid
            && request.resource.data.requestedBy == resource.data.requestedBy);
      allow delete: if isAmy();

      match /upvotes/{uid} {
        allow read: if isApproved();
        allow write: if isSelf(uid) && isApproved();
      }
    }
  }
}
