rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function userExists() { return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function isApproved() { return userExists() && userDoc().status == 'approved'; }
    function isAmy() { return userExists() && userDoc().role == 'amy' && userDoc().status == 'approved'; }
    function isSelf(uid) { return isSignedIn() && request.auth.uid == uid; }

    match /users/{uid} {
      // Self can read own doc; Amy can read all users.
      allow read: if isSelf(uid) || isAmy();

      // First-time create must be self, employee, pending (no privilege escalation).
      allow create: if isSelf(uid)
        && request.resource.data.role == 'employee'
        && request.resource.data.status == 'pending';

      // Self can only update displayName (role + status are immutable from client).
      allow update: if isAmy()
        || (isSelf(uid)
            && request.resource.data.role == resource.data.role
            && request.resource.data.status == resource.data.status
            && request.resource.data.email == resource.data.email);

      allow delete: if false;
    }

    match /mealLibrary/{libId} {
      allow read: if isApproved();
      allow write: if isAmy();
    }

    match /servings/{servingId} {
      allow read: if isApproved();
      allow write: if isAmy();

      match /ratings/{uid} {
        allow read: if isApproved();
        // Employee writes their own rating; Amy can hide/delete.
        allow create, update: if (isSelf(uid) && isApproved()
                                  && request.resource.data.stars is int
                                  && request.resource.data.stars >= 1
                                  && request.resource.data.stars <= 5)
                                 || isAmy();
        allow delete: if isAmy();
      }

      match /lookingForward/{uid} {
        allow read: if isApproved();
        allow write: if isSelf(uid) && isApproved();
      }
    }

    match /requests/{reqId} {
      allow read: if isApproved();
      allow create: if isApproved() && request.resource.data.requestedBy == request.auth.uid;
      allow update: if isAmy()
        || (isApproved()
            && resource.data.requestedBy == request.auth.uid
            && request.resource.data.requestedBy == resource.data.requestedBy);
      allow delete: if isAmy();

      match /upvotes/{uid} {
        allow read: if isApproved();
        allow write: if isSelf(uid) && isApproved();
      }
    }
  }
}
