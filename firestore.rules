rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function userExists() { return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function isApproved() { return userExists() && userDoc().status == 'approved'; }
    function isAmy() { return userExists() && userDoc().role == 'amy' && userDoc().status == 'approved'; }
    function isSelf(uid) { return isSignedIn() && request.auth.uid == uid; }

    match /users/{uid} {
      allow read: if isSelf(uid) || isApproved();

      // First-time create: employee+pending self, OR known-admin email
      // self-bootstrapping as approved admin (defensive belt-and-braces
      // for when Firebase doesn't auto-link Google to email-link UIDs).
      allow create: if isSelf(uid)
        && (
          (request.resource.data.role == 'employee'
            && request.resource.data.status == 'pending')
          ||
          (request.auth.token.email in ['sbezner@gmail.com', 'abezner@gmail.com']
            && request.resource.data.role == 'amy'
            && request.resource.data.status == 'approved')
        );

      allow update: if (isAmy()
        || (isSelf(uid)
            && request.resource.data.role == resource.data.role
            && request.resource.data.status == resource.data.status
            && request.resource.data.email == resource.data.email))
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 50;

      allow delete: if false;
    }

    match /mealLibrary/{libId} {
      allow read: if isApproved();

      // Anyone approved can add or edit a meal entry. String-length and
      // photo-array caps keep payloads sane.
      allow create, update: if isApproved()
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 120
        && (!('description' in request.resource.data)
            || request.resource.data.description is string
            && request.resource.data.description.size() <= 2000)
        && (!('photos' in request.resource.data)
            || (request.resource.data.photos is list
                && request.resource.data.photos.size() <= 6));

      // Only Amy can delete a meal that's been served, but the creator
      // of an un-served meal can also delete their own. The "no
      // servings exist" check is enforced client-side; this is fine
      // because an approved user could only orphan their own data.
      allow delete: if isAmy()
        || (isApproved()
            && resource.data.get('createdBy', '') == request.auth.uid);

      // Ratings: 1 per (meal, user). Same shape as before, new home.
      match /ratings/{uid} {
        allow read: if isApproved();
        allow create: if (isSelf(uid) && isApproved()
                          && request.resource.data.stars is int
                          && request.resource.data.stars >= 1
                          && request.resource.data.stars <= 5
                          && (!('comment' in request.resource.data)
                              || request.resource.data.comment is string
                              && request.resource.data.comment.size() <= 1000)
                          && request.resource.data.get('hiddenByAmy', false) == false)
                         || isAmy();
        allow update: if (isSelf(uid) && isApproved()
                          && request.resource.data.stars is int
                          && request.resource.data.stars >= 1
                          && request.resource.data.stars <= 5
                          && (!('comment' in request.resource.data)
                              || request.resource.data.comment is string
                              && request.resource.data.comment.size() <= 1000)
                          && request.resource.data.get('hiddenByAmy', false) == resource.data.get('hiddenByAmy', false))
                         || isAmy();
        allow delete: if isSelf(uid) || isAmy();
      }

      // "Make this again" upvotes — one per (meal, user).
      match /upvotes/{uid} {
        allow read: if isApproved();
        allow write: if isSelf(uid) && isApproved();
      }
    }

    match /servings/{servingId} {
      allow read: if isApproved();
      allow create, update: if isApproved()
        && (!('notes' in request.resource.data)
            || request.resource.data.notes == null
            || (request.resource.data.notes is string
                && request.resource.data.notes.size() <= 500));
      allow delete: if isAmy();

      match /lookingForward/{uid} {
        allow read: if isApproved();
        allow write: if isSelf(uid) && isApproved();
      }
    }
  }
}
